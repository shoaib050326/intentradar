generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  plan      String     @default("starter")
  createdAt DateTime   @default(now())
  watchlists Watchlist[]
  leadActions LeadAction[]
}

model Watchlist {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime            @default(now())
  sources   WatchlistSource[]
  keywords  WatchlistKeyword[]
}

model WatchlistSource {
  id          String    @id @default(cuid())
  watchlistId String
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  subreddit   String
}

model WatchlistKeyword {
  id          String    @id @default(cuid())
  watchlistId String
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  keyword     String
}

model Post {
  id          String         @id @default(cuid())
  postId      String         @unique
  title       String
  body        String?
  author      String
  subreddit   String
  url         String
  createdAt   DateTime
  score       Int            @default(0)
  numComments Int            @default(0)
  leadCandidate LeadCandidate?
}

model LeadCandidate {
  id           String      @id @default(cuid())
  postId       String      @unique
  post         Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  intentScore  Int
  intentBucket String
  painSummary  String?
  reasonCodes  String[]
  createdAt    DateTime    @default(now())
  draftReplies DraftReply[]
  leadActions  LeadAction[]
}

model DraftReply {
  id        String         @id @default(cuid())
  leadId    String
  lead      LeadCandidate  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  replyText String
  tone      String         @default("helpful")
  createdAt DateTime       @default(now())
}

model LeadAction {
  id         String         @id @default(cuid())
  leadId     String
  lead       LeadCandidate  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionType String
  createdAt  DateTime       @default(now())
}
